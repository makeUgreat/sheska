{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/pr_harness_check.js\"",
            "if": "Bash(gh pr create*)",
            "timeout": 600,
            "statusMessage": "Running full harness (static + build) before opening PR"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/mark_dirty.js\"",
            "timeout": 30,
            "statusMessage": "Marking repository dirty for static checks"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/stop_check.js\"",
            "timeout": 600,
            "statusMessage": "Running static analysis harness"
          }
        ]
      }
    ]
  }
}
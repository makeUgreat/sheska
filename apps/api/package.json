{
  "name": "@sheska/api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint --config eslint/config.mjs \"{src,test}/**/*.ts\" --fix",
    "lint:check": "eslint --config eslint/config.mjs \"{src,test}/**/*.ts\"",
    "deps:check": "depcruise src test --config dependency-cruiser/config.cjs",
    "deps:graph": "depcruise src test --config dependency-cruiser/config.cjs --output-type mermaid --output-to dependency-graph.mmd",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "harness:static": "pnpm typecheck && pnpm lint:check && pnpm deps:check",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:integration:all",
    "test:unit": "vitest run --exclude \"test/**/*.e2e-spec.ts\"",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:postgres": "vitest run --config vitest.postgres.integration.config.ts",
    "test:integration:all": "pnpm test:integration && pnpm test:integration:postgres",
    "test:e2e": "pnpm test:integration",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --no-file-parallelism"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "drizzle-orm": "1.0.0-beta.22",
    "neverthrow": "^8.2.0",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.40",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "drizzle-kit": "1.0.0-beta.22",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.7"
  }
}
